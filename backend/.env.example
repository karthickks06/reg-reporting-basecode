# Copy this file to .env and update the values before starting the backend.
# The backend reads settings from this file via pydantic-settings.

# -----------------------------------------------------------------------
# Database — must point to the PostgreSQL instance with pgvector installed
# Default matches the docker-compose service name "postgres"
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://fca_user:fca_pass@localhost:5431/fca_app

# -----------------------------------------------------------------------
# Redis (optional — only required if REQUIRE_REDIS=true)
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS=false

# -----------------------------------------------------------------------
# Schema / migration behaviour
# auto_create_schema=true  → Base.metadata.create_all() runs on startup
#                            (creates tables defined in app/models.py only)
# auto_run_migrations=false → alembic upgrade head is NOT called on startup;
#                              run it manually (or via entrypoint.sh in Docker)
# -----------------------------------------------------------------------
AUTO_CREATE_SCHEMA=true
AUTO_RUN_MIGRATIONS=false

# -----------------------------------------------------------------------
# LLM endpoint — Azure OpenAI GPT-4.1 (Required)
# -----------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://agent-alm.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=4dNMnTZ8rBU71dAcnMrnCCifSLmKTq5GZtKmRAZmqQHehrJpt4jqJQQJ99CCACYeBjFXJ3w3AAABACOGWvU5
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
ENVIRONMENT=local
API_PORT=8000
APP_LOG_LEVEL=INFO
ADMIN_API_KEY=
EMBEDDING_DIM=768
