# Copy this file to backend/.env for local development without Docker or Podman.
# The backend is started from the backend/ directory by start-native.ps1.

ENVIRONMENT=local-native
API_PORT=8000
APP_LOG_LEVEL=INFO
STARTUP_PROBE_TIMEOUT_SECONDS=3

# Repo-local runtime data. Relative paths are resolved from backend/.
DATA_ROOT=../data

# Native local persistence: no external database service required.
DATABASE_URL=sqlite:///../data/reg_reporting_local.db
AUTO_CREATE_SCHEMA=true
AUTO_APPLY_SCHEMA_PATCHES=true

# Redis is optional in this application.
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS=false

# LLM endpoint - required only for LLM-backed features.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication
ADMIN_API_KEY=
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_BOOTSTRAP_ENABLED=true
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_EMAIL=admin@example.com
AUTH_BOOTSTRAP_PASSWORD=Admin123!

# Embedded Chroma. Keep CHROMA_HOST blank for no separate Chroma server.
EMBEDDING_DIM=768
VECTOR_STORE=chroma
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_chunks
CHROMA_PERSIST_DIR=../data/chroma
