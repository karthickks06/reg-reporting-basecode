# Project-level local defaults.
# The backend launcher reads backend/.env. For local native runs, copy:
#   backend/.env.native.example -> backend/.env

ENVIRONMENT=local-native
API_PORT=8000
FRONTEND_PORT=3000
APP_LOG_LEVEL=INFO
STARTUP_PROBE_TIMEOUT_SECONDS=3

# Local native persistence.
DATA_ROOT=../data
DATABASE_URL=sqlite:///../data/reg_reporting_local.db
AUTO_CREATE_SCHEMA=true
AUTO_APPLY_SCHEMA_PATCHES=true

# Redis is optional in the local app.
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS=false

# Azure OpenAI. Required only for LLM-backed features.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication.
ADMIN_API_KEY=
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_BOOTSTRAP_ENABLED=true
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_EMAIL=admin@example.com
AUTH_BOOTSTRAP_PASSWORD=Admin123!

# Embedded Chroma for native local runs. Keep CHROMA_HOST blank.
EMBEDDING_DIM=768
VECTOR_STORE=chroma
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_chunks
CHROMA_PERSIST_DIR=../data/chroma
